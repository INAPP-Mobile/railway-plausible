# =============================================================================
# Plausible Community Edition - Required Environment Variables
# =============================================================================
# Railway auto-generates DATABASE_URL from the PostgreSQL plugin.
# You MUST set BASE_URL and SECRET_KEY_BASE before deploying.

# --- Required ---

# Public URL where Plausible will be accessible (no trailing slash)
BASE_URL=https://plausible.yourdomain.com

# 64-byte random string for cookie signing and secrets
# Generate with: openssl rand -base64 48
SECRET_KEY_BASE=replace...this...with...a...64...byte...random...string

# PostgreSQL connection string. Points to the sibling 'postgres' service
# (postgres:16-alpine) — NOT the Railway postgres-ssl:18 plugin (which crashes
# on first boot due to the ext4 lost+found gotcha; see postgres/.env.example
# for the parent-mount geometry explanation).
#
# If you rotate POSTGRES_PASSWORD on the postgres service via the dashboard,
# update this DATABASE_URL to match (literal form). Defaults match postgres/
# template-vars.json out of the box.
DATABASE_URL=postgresql://postgres:postgres@postgres.railway.internal:5432/plausible

# ClickHouse connection string (internal Railway DNS, with literal credentials).
# Update CLICKHOUSE_PASSWORD on the ClickHouse tile (and on this URL) if you change the default.
CLICKHOUSE_DATABASE_URL=http://plausible:plausible2026@clickhouse.railway.internal:8123/plausible

# --- Optional: Customization ---

# Server port (default: 8000, Railway sets PORT env var)
# HTTP_PORT=8000

# Disable public registration after first admin user is created
# DISABLE_REGISTRATION=true

# Enable email verification for new users
# ENABLE_EMAIL_VERIFICATION=true

# TOTP vault encryption key
# TOTP_VAULT_KEY=your-totp-vault-key

# --- Optional: Email (SMTP) ---

# MAILER_ADAPTER=smtp
# MAILER_EMAIL=plausible@yourdomain.com
# MAILER_NAME=Plausible
# SMTP_HOST_ADDR=smtp.yourdomain.com
# SMTP_HOST_PORT=587
# SMTP_USER_NAME=your-smtp-user
# SMTP_USER_PWD=your-smtp-password
# SMTP_HOST_SSL_ENABLED=true

# --- Optional: Google Auth ---

# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Optional: IP Geolocation ---

# IP_GEOLOCATION_DB=city
# MAXMIND_LICENSE_KEY=your-maxmind-license-key
